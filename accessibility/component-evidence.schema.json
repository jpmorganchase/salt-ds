{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jpmorganchase/salt-ds/main/accessibility/component-evidence.schema.json",
  "title": "Salt component accessibility evidence",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "conformanceTarget",
    "publicDocumentation",
    "supportMatrix",
    "components"
  ],
  "properties": {
    "$schema": { "const": "./component-evidence.schema.json" },
    "schemaVersion": { "const": 1 },
    "conformanceTarget": { "const": "WCAG 2.2 Level AA" },
    "publicDocumentation": { "type": "string", "minLength": 1 },
    "supportMatrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "operatingSystem", "browser", "assistiveTechnology"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "operatingSystem": { "type": "string", "minLength": 1 },
          "browser": { "type": "string", "minLength": 1 },
          "assistiveTechnology": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "components": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "package",
          "owner",
          "status",
          "formallyConformant",
          "reviewedOn",
          "reviewBy",
          "documentation",
          "successCriteria",
          "automatedEvidence",
          "manualEvidence",
          "exceptions",
          "limitations"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "package": { "const": "@salt-ds/core" },
          "owner": { "type": "string", "minLength": 1 },
          "status": { "enum": ["target", "tested", "supported", "exception"] },
          "formallyConformant": { "const": false },
          "reviewedOn": { "type": "string", "format": "date" },
          "reviewBy": { "type": "string", "format": "date" },
          "documentation": { "type": "string", "minLength": 1 },
          "successCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["criterion", "level", "evidenceIds"],
              "properties": {
                "criterion": {
                  "type": "string",
                  "pattern": "^[1-4]\\.[0-9]+\\.[0-9]+$"
                },
                "level": { "enum": ["A", "AA"] },
                "evidenceIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            }
          },
          "automatedEvidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "kind",
                "path",
                "covers",
                "status",
                "recordedOn",
                "command"
              ],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "kind": { "enum": ["axe", "behavior", "keyboard"] },
                "path": { "type": "string", "minLength": 1 },
                "covers": { "type": "string", "minLength": 1 },
                "status": { "enum": ["passed", "failed"] },
                "recordedOn": { "type": "string", "format": "date" },
                "command": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "manualEvidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["matrixId", "status", "scenarios", "recordedOn"],
              "properties": {
                "matrixId": { "type": "string", "minLength": 1 },
                "status": {
                  "enum": ["not-tested", "passed", "failed", "blocked"]
                },
                "scenarios": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "recordedOn": { "type": ["string", "null"], "format": "date" },
                "notes": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "exceptions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "impact",
                "owner",
                "status",
                "reviewBy",
                "successCriteria"
              ],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "impact": { "type": "string", "minLength": 1 },
                "owner": { "type": "string", "minLength": 1 },
                "status": { "enum": ["open", "accepted", "resolved"] },
                "reviewBy": { "type": "string", "format": "date" },
                "successCriteria": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "pattern": "^[1-4]\\.[0-9]+\\.[0-9]+$"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
