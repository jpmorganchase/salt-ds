{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext", "WebWorker"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "paths": {
      ".storybook/*": ["./.storybook/*"],
      "@stories/*": [
        "./packages/ag-grid-theme/stories/*",
        "./packages/core/stories/*",
        "./packages/data-grid/stories/*",
        "./packages/date-components/stories/*",
        "./packages/icons/stories/*",
        "./packages/lab/stories/*",
        "./packages/embla-carousel/stories/*",
        "./packages/theme/stories/*"
      ],
      "@salt-ds/date-adapters/*": [
        "./packages/date-adapters/src/*-adapter/index.ts"
      ],
      "packages/*": ["./packages/*"]
    },
    "types": [
      "cypress",
      "@testing-library/cypress",
      "node",
      "cypress-real-events"
    ]
  },
  "include": [
    "packages",
    "integration/toolkit",
    ".storybook/decorators",
    "docs",
    "tooling",
    "cypress",
    "cypress/types.d.ts",
    "./declarations.d.ts"
  ]
}
