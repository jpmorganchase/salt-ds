{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Toggle Button",
  "description": "Single-select toggle control for standalone two-state actions and grouped mutually exclusive choices.",
  "package": "@salt-ds/core",
  "import": "import { ToggleButton, ToggleButtonGroup } from \"@salt-ds/core\";",
  "status": "stable",
  "props": {
    "ToggleButton.value": {
      "type": "string | ReadonlyArray<string> | number | undefined",
      "required": true,
      "description": "Value used by controlled and grouped selection logic"
    },
    "ToggleButton.selected": {
      "type": "boolean",
      "description": "Controlled selected state"
    },
    "ToggleButton.defaultSelected": {
      "type": "boolean",
      "default": "false",
      "description": "Initial selected state for uncontrolled usage"
    },
    "ToggleButton.onChange": {
      "type": "(event: MouseEvent<HTMLButtonElement>) => void",
      "description": "Called when toggle selection changes"
    },
    "ToggleButton.appearance": {
      "type": "'solid' | 'bordered'",
      "default": "'solid'",
      "description": "Visual appearance when selected"
    },
    "ToggleButton.sentiment": {
      "type": "ButtonSentiment",
      "default": "'neutral'",
      "description": "Visual sentiment styling"
    },
    "ToggleButton.readOnly": {
      "type": "boolean",
      "default": "false",
      "description": "Prevents selection changes while preserving readability"
    },
    "ToggleButton.disabled": {
      "type": "boolean",
      "default": "false",
      "description": "Disables interaction"
    },
    "ToggleButtonGroup.value": {
      "type": "string | number",
      "description": "Controlled selected value"
    },
    "ToggleButtonGroup.defaultValue": {
      "type": "string | number",
      "description": "Initial selected value for uncontrolled group"
    },
    "ToggleButtonGroup.onChange": {
      "type": "(event: SyntheticEvent<HTMLButtonElement>) => void",
      "description": "Called when selected toggle changes"
    },
    "ToggleButtonGroup.orientation": {
      "type": "'horizontal' | 'vertical'",
      "default": "'horizontal'",
      "description": "Layout direction for grouped toggles"
    },
    "ToggleButtonGroup.appearance": {
      "type": "'solid' | 'bordered'",
      "default": "'solid'",
      "description": "Shared appearance applied to group items"
    },
    "ToggleButtonGroup.sentiment": {
      "type": "ButtonSentiment",
      "default": "'neutral'",
      "description": "Shared sentiment applied to group items"
    },
    "ToggleButtonGroup.readOnly": {
      "type": "boolean",
      "default": "false",
      "description": "Group is non-interactive while selected value remains perceivable"
    },
    "ToggleButtonGroup.disabled": {
      "type": "boolean",
      "default": "false",
      "description": "Disables all toggles in the group"
    }
  },
  "slots": {
    "ToggleButton.children": "Button label content and optional icon",
    "ToggleButtonGroup.children": "Two or more related ToggleButton options"
  },
  "states": [
    "default",
    "selected",
    "disabled",
    "readOnly"
  ],
  "tokens": {
    "textFontFamily": "--salt-text-action-fontFamily",
    "textFontWeight": "--salt-text-action-fontWeight",
    "textLetterSpacing": "--salt-text-action-letterSpacing",
    "groupBackground": "--salt-container-primary-background",
    "groupBorderColor": "--salt-container-primary-borderColor",
    "groupDisabledBackground": "--salt-container-primary-background-disabled",
    "groupDisabledBorderColor": "--salt-container-primary-borderColor-disabled",
    "neutralSubtleBackground": "--salt-actionable-subtle-background",
    "neutralSelectedBackground": "--salt-actionable-background-selected",
    "neutralBorderColor": "--salt-actionable-subtle-borderColor",
    "accentedBackground": "--salt-actionable-accented-subtle-background",
    "positiveBackground": "--salt-actionable-positive-subtle-background",
    "negativeBackground": "--salt-actionable-negative-subtle-background",
    "cautionBackground": "--salt-actionable-caution-subtle-background"
  },
  "accessibility": {
    "role": "button (standalone), radiogroup/radio (grouped)",
    "keyboard": [
      "Tab",
      "Shift+Tab",
      "Space",
      "Enter",
      "ArrowRight",
      "ArrowDown",
      "ArrowLeft",
      "ArrowUp"
    ],
    "aria": [
      "Standalone ToggleButton uses `aria-pressed` to convey selected state",
      "ToggleButton inside ToggleButtonGroup uses `role=radio` and `aria-checked`",
      "ToggleButtonGroup uses `role=radiogroup`",
      "When icon and text are both present, set icon `aria-hidden`",
      "When icon-only, provide an accessible `aria-label` on the button"
    ]
  },
  "composition": {
    "with": [
      "Tooltip",
      "FlowLayout",
      "Icon"
    ],
    "inside": [
      "Toolbar",
      "Panel",
      "Card",
      "Form controls area"
    ]
  },
  "docsUrl": "https://www.saltdesignsystem.com/salt/components/toggle-button/examples"
}
