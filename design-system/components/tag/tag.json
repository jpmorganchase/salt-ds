{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Tag",
  "description": "Displays short, non-interactive metadata labels for categorization.",
  "package": "@salt-ds/core",
  "import": "import { Tag } from \"@salt-ds/core\";",
  "status": "stable",
  "props": {
    "variant": {
      "type": "'primary' | 'secondary'",
      "default": "'primary'",
      "description": "Visual emphasis variant"
    },
    "bordered": {
      "type": "boolean",
      "default": "false",
      "description": "Adds full border styling"
    },
    "category": {
      "type": "number",
      "default": "1",
      "description": "Categorical color index intended for range 1 to 20"
    },
    "children": {
      "type": "ReactNode",
      "description": "Tag content, typically one to two words and optional leading icon"
    }
  },
  "slots": {
    "children": "Tag label content and optional icon"
  },
  "states": [
    "default"
  ],
  "tokens": {
    "primaryBackground": "--salt-category-1-background",
    "primaryForeground": "--salt-category-1-foreground",
    "primaryBorderColor": "--salt-category-1-borderColor",
    "secondaryBackground": "--salt-category-1-bold-background",
    "secondaryForeground": "--salt-content-bold-foreground"
  },
  "accessibility": {
    "role": "varies",
    "keyboard": [],
    "aria": [
      "Use readable text or icon+text labels so meaning is not conveyed by color alone",
      "When using category colors, ensure text labels remain the primary differentiator"
    ]
  },
  "composition": {
    "with": [
      "Card",
      "Text",
      "Icon"
    ],
    "inside": [
      "Card",
      "Catalog/listing views",
      "Metadata groupings"
    ]
  },
  "docsUrl": "https://www.saltdesignsystem.com/salt/components/tag/examples"
}
