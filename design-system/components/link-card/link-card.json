{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "LinkCard",
  "description": "Card-styled anchor for navigational entry points to related detail pages.",
  "package": "@salt-ds/core",
  "import": "import { LinkCard } from \"@salt-ds/core\";",
  "status": "stable",
  "props": {
    "href": {
      "type": "string",
      "description": "Anchor destination URL."
    },
    "target": {
      "type": "'_self' | '_blank' | '_parent' | '_top' | string",
      "default": "'_self'",
      "description": "Where to open linked destination."
    },
    "rel": {
      "type": "string",
      "description": "Relationship for linked resource (set `noopener`/`noreferrer` for cross-origin `_blank` targets)."
    },
    "accent": {
      "type": "'bottom' | 'top' | 'left' | 'right'",
      "default": "'bottom'",
      "description": "Accent strip position on the card."
    },
    "variant": {
      "type": "'primary' | 'secondary' | 'tertiary'",
      "default": "'primary'",
      "description": "Visual surface variant."
    }
  },
  "slots": {
    "children": "Card content (for example heading, summary text, and metadata)."
  },
  "states": [
    "default",
    "hover",
    "focus-visible",
    "active",
    "accent-top",
    "accent-right",
    "accent-bottom",
    "accent-left",
    "variant-primary",
    "variant-secondary",
    "variant-tertiary"
  ],
  "tokens": {
    "padding": "--saltLinkCard-padding",
    "background": "--saltLinkCard-background",
    "accentColor": "--saltLinkCard-accent-color",
    "focusOutlineColor": "--salt-focused-outlineColor"
  },
  "accessibility": {
    "role": "semantic anchor (`a`)",
    "keyboard": [
      "Tab/Shift+Tab move focus to/from the card link",
      "Enter activates navigation"
    ],
    "aria": [
      "Card content should provide a clear accessible name for destination context",
      "Avoid nested interactive controls inside the anchor region",
      "Use descriptive heading/body copy so destination is understandable before activation"
    ]
  },
  "composition": {
    "with": [
      "H3",
      "Text",
      "StackLayout"
    ],
    "inside": [
      "Dashboard summary tiles",
      "Content discovery cards",
      "Navigation hubs"
    ]
  },
  "docsUrl": "https://www.saltdesignsystem.com/salt/components/link-card/examples"
}
