{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Divider",
  "description": "Separates elements, regions, and containers with horizontal or vertical visual dividers.",
  "package": "@salt-ds/core",
  "import": "import { Divider } from \"@salt-ds/core\";",
  "status": "stable",
  "props": {
    "orientation": {
      "type": "'horizontal' | 'vertical'",
      "default": "'horizontal'",
      "description": "Sets divider direction relative to surrounding layout."
    },
    "variant": {
      "type": "'primary' | 'secondary' | 'tertiary'",
      "default": "'primary'",
      "description": "Controls separator emphasis and contrast level."
    }
  },
  "slots": {
    "children": "Not typically used; Divider is generally rendered as an empty separator element."
  },
  "states": [
    "horizontal",
    "vertical",
    "primary",
    "secondary",
    "tertiary"
  ],
  "tokens": {
    "colorPrimary": "--salt-separable-primary-borderColor",
    "colorSecondary": "--salt-separable-secondary-borderColor",
    "colorTertiary": "--salt-separable-tertiary-borderColor"
  },
  "accessibility": {
    "role": "separator",
    "keyboard": [
      "None — Divider is non-interactive and not keyboard focusable"
    ],
    "aria": [
      "role=\"separator\" is applied by default",
      "aria-orientation reflects `orientation` (`horizontal` or `vertical`)",
      "Set `aria-hidden=\"true\"` when Divider is decorative-only"
    ]
  },
  "composition": {
    "with": [
      "StackLayout (separating stacked content)",
      "FlexLayout (separating adjacent regions)",
      "Card, Panel, Overlay content (subsection separation)"
    ],
    "inside": [
      "General page and container layouts",
      "Lists and content sections where visual separation is needed"
    ]
  },
  "docsUrl": "https://www.saltdesignsystem.com/salt/components/divider/examples"
}
