{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Toast",
  "description": "Transient notification container for low-priority or peripheral updates, with optional status icon and actionable content.",
  "package": "@salt-ds/core",
  "import": "import { Toast, ToastContent } from \"@salt-ds/core\";",
  "status": "stable",
  "props": {
    "status": {
      "type": "'info' | 'error' | 'warning' | 'success'",
      "description": "Determines validation/status treatment and default status indicator icon"
    },
    "icon": {
      "type": "ReactElement<IconProps>",
      "description": "Optional custom icon displayed instead of the default status indicator when `status` is set"
    },
    "children": {
      "type": "ReactNode",
      "description": "Toast body content, typically `ToastContent` and optional action/dismiss controls"
    }
  },
  "slots": {
    "children": "Notification body and optional controls",
    "content": "Use `ToastContent` for the text/content region"
  },
  "states": [
    "default",
    "info",
    "error",
    "warning",
    "success"
  ],
  "tokens": {
    "background": "--salt-container-primary-background",
    "borderColor": "--salt-container-primary-borderColor",
    "statusInfoBorderColor": "--salt-status-info-borderColor",
    "statusErrorBorderColor": "--salt-status-error-borderColor",
    "statusWarningBorderColor": "--salt-status-warning-borderColor",
    "statusSuccessBorderColor": "--salt-status-success-borderColor",
    "statusInfoIconColor": "--salt-status-info-foreground-decorative",
    "statusErrorIconColor": "--salt-status-error-foreground-decorative",
    "statusWarningIconColor": "--salt-status-warning-foreground-decorative",
    "statusSuccessIconColor": "--salt-status-success-foreground-decorative",
    "textFontFamily": "--salt-text-fontFamily",
    "textFontSize": "--salt-text-fontSize",
    "textLineHeight": "--salt-text-lineHeight",
    "shadow": "--salt-overlayable-shadow-popout",
    "radius": "--salt-palette-corner"
  },
  "accessibility": {
    "role": "alert",
    "keyboard": [
      "Tab",
      "Shift+Tab"
    ],
    "aria": [
      "Toast root uses `role=alert` to announce messages",
      "Ensure focus order is valid for any interactive elements included in toast content",
      "Provide clear dismiss/action labels for icon-only buttons"
    ]
  },
  "composition": {
    "with": [
      "ToastContent",
      "Button",
      "Link",
      "Text"
    ],
    "inside": [
      "App-level toast container",
      "Fixed viewport edge container",
      "ToastGroup (@salt-ds/lab)"
    ]
  },
  "docsUrl": "https://www.saltdesignsystem.com/salt/components/toast/examples"
}
