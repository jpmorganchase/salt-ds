{
  "name": "Typography",
  "description": "Salt typography tokens and text component variants. Use Salt text components and typography tokens — never hard-code font properties.",
  "fontFamilies": {
    "--salt-typography-fontFamily": {
      "value": "Open Sans",
      "description": "Default font family for all UI text"
    },
    "--salt-typography-fontFamily-code": {
      "value": "PT Mono",
      "description": "Monospace font for code and technical content"
    }
  },
  "fontWeights": {
    "--salt-typography-fontWeight-light": {
      "value": 300,
      "description": "Light weight — subtle, de-emphasized text"
    },
    "--salt-typography-fontWeight-regular": {
      "value": 400,
      "description": "Regular weight — body text default"
    },
    "--salt-typography-fontWeight-medium": {
      "value": 500,
      "description": "Medium weight — slight emphasis"
    },
    "--salt-typography-fontWeight-semiBold": {
      "value": 600,
      "description": "Semi-bold — headings, labels"
    },
    "--salt-typography-fontWeight-bold": {
      "value": 700,
      "description": "Bold — strong emphasis"
    }
  },
  "fontSizes": {
    "--salt-text-fontSize": {
      "description": "Base body text font size"
    },
    "--salt-text-h1-fontSize": {
      "description": "H1 heading font size"
    },
    "--salt-text-h2-fontSize": {
      "description": "H2 heading font size"
    },
    "--salt-text-h3-fontSize": {
      "description": "H3 heading font size"
    },
    "--salt-text-h4-fontSize": {
      "description": "H4 heading font size"
    },
    "--salt-text-display1-fontSize": {
      "description": "Display 1 font size (largest)"
    },
    "--salt-text-display2-fontSize": {
      "description": "Display 2 font size"
    },
    "--salt-text-display3-fontSize": {
      "description": "Display 3 font size"
    },
    "--salt-text-label-fontSize": {
      "description": "Label font size"
    },
    "--salt-text-notation-fontSize": {
      "description": "Notation (caption/footnote) font size"
    }
  },
  "lineHeights": {
    "--salt-text-lineHeight": {
      "description": "Base body text line height"
    },
    "--salt-text-h1-lineHeight": {
      "description": "H1 heading line height"
    },
    "--salt-text-h2-lineHeight": {
      "description": "H2 heading line height"
    },
    "--salt-text-h3-lineHeight": {
      "description": "H3 heading line height"
    },
    "--salt-text-h4-lineHeight": {
      "description": "H4 heading line height"
    }
  },
  "textComponents": {
    "Display": {
      "component": "<Display1>, <Display2>, <Display3>",
      "description": "Hero text and prominent page titles. Largest text styles.",
      "import": "import { Display1, Display2, Display3 } from \"@salt-ds/core\";"
    },
    "H1": {
      "component": "<H1>",
      "description": "Top-level section heading.",
      "import": "import { H1 } from \"@salt-ds/core\";"
    },
    "H2": {
      "component": "<H2>",
      "description": "Second-level section heading.",
      "import": "import { H2 } from \"@salt-ds/core\";"
    },
    "H3": {
      "component": "<H3>",
      "description": "Third-level section heading.",
      "import": "import { H3 } from \"@salt-ds/core\";"
    },
    "H4": {
      "component": "<H4>",
      "description": "Fourth-level section heading.",
      "import": "import { H4 } from \"@salt-ds/core\";"
    },
    "Text": {
      "component": "<Text>",
      "description": "Body copy, labels, annotations. Supports styleAs prop for visual variants without changing semantic level.",
      "import": "import { Text } from \"@salt-ds/core\";"
    },
    "Label": {
      "component": "<Label>",
      "description": "Form field labels and short annotations.",
      "import": "import { Label } from \"@salt-ds/core\";"
    }
  }
}
