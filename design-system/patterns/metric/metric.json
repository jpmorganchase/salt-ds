{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Metric",
  "description": "A pattern for displaying an important value with optional context like subtitle, subvalue, link, and directional indicators.",
  "status": "stable",
  "sourceOfTruth": {
    "docs": "https://github.com/jpmorganchase/salt-ds/tree/main/site/docs/patterns/metric.mdx",
    "stories": "https://github.com/jpmorganchase/salt-ds/tree/main/packages/core/stories/patterns/metric/metric.stories.tsx",
    "storybook": "https://storybook.saltdesignsystem.com/?path=/story/patterns-metric--metric"
  },
  "componentsUsed": [
    "Text",
    "StackLayout",
    "Link",
    "Icon"
  ],
  "composition": {
    "tree": [
      "StackLayout (root)",
      "Text (title)",
      "Text or Link (subtitle, optional)",
      "Display text (value)",
      "Icon (indicator, optional, inline with value)",
      "Text (subvalue, optional)"
    ],
    "orderRules": [
      "Render title above value in vertical orientation.",
      "Render title and value in a row for horizontal orientation.",
      "When subtitle exists, place it directly below title.",
      "When subvalue exists, place it below value.",
      "When indicator exists, render it inline with value and match sentiment color with subvalue." 
    ]
  },
  "variantAxes": {
    "orientation": [
      "vertical",
      "horizontal"
    ],
    "size": [
      "small",
      "medium",
      "large"
    ],
    "context": [
      "title+value",
      "title+subtitle+value",
      "title+subtitle+value+subvalue",
      "title+linkSubtitle+value+subvalue"
    ],
    "indicator": [
      "none",
      "up",
      "down"
    ],
    "hierarchy": [
      "single",
      "hierarchical-set"
    ]
  },
  "variantMatrix": [
    {
      "name": "Base metric",
      "orientation": "vertical",
      "size": "large",
      "context": "title+value",
      "indicator": "none",
      "hierarchy": "single",
      "evidence": "Patterns/Metric -> Metric",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Horizontal metric",
      "orientation": "horizontal",
      "size": "large",
      "context": "title+value",
      "indicator": "none",
      "hierarchy": "single",
      "evidence": "Patterns/Metric -> Horizontal Metric",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Subtitle",
      "orientation": "vertical",
      "size": "large",
      "context": "title+subtitle+value",
      "indicator": "none",
      "hierarchy": "single",
      "evidence": "Patterns/Metric -> Subtitle",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Subvalue",
      "orientation": "vertical",
      "size": "large",
      "context": "title+subtitle+value+subvalue",
      "indicator": "none",
      "hierarchy": "single",
      "evidence": "Patterns/Metric -> Subvalue",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Link subtitle",
      "orientation": "vertical",
      "size": "large",
      "context": "title+linkSubtitle+value+subvalue",
      "indicator": "none",
      "hierarchy": "single",
      "evidence": "Patterns/Metric -> Link Subtitle",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Indicators",
      "orientation": "vertical",
      "size": "large",
      "context": "title+subtitle+value+subvalue",
      "indicator": "up/down",
      "hierarchy": "single",
      "evidence": "Patterns/Metric -> Indicators",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Hierarchical vertical",
      "orientation": "vertical",
      "size": "small|medium|large",
      "context": "title+subtitle+value+subvalue",
      "indicator": "up",
      "hierarchy": "hierarchical-set",
      "evidence": "Patterns/Metric -> Hierarchical Vertical",
      "evidenceType": "story",
      "inferred": false
    },
    {
      "name": "Hierarchical horizontal",
      "orientation": "horizontal",
      "size": "small|medium|large",
      "context": "title+value",
      "indicator": "none",
      "hierarchy": "hierarchical-set",
      "evidence": "Patterns/Metric -> Hierarchical Horizontal",
      "evidenceType": "story",
      "inferred": false
    }
  ],
  "tokens": {
    "typography": {
      "smallValue": "Display3",
      "mediumValue": "Display2",
      "largeValue": "Display1",
      "title": "Text + strong",
      "subtitle": "Text variant=secondary",
      "subvalue": "Text with sentiment informative foreground"
    },
    "spacing": {
      "verticalStackGap": "0",
      "horizontalGap": "var(--salt-spacing-100)",
      "horizontalTitleMarginTop": {
        "small": "var(--salt-spacing-50)",
        "medium": "var(--salt-spacing-100)",
        "large": "var(--salt-spacing-150)"
      }
    },
    "color": {
      "positiveIndicator": "var(--salt-sentiment-positive-foreground-decorative)",
      "negativeIndicator": "var(--salt-sentiment-negative-foreground-decorative)",
      "positiveSubvalue": "var(--salt-sentiment-positive-foreground-informative)",
      "negativeSubvalue": "var(--salt-sentiment-negative-foreground-informative)"
    },
    "icon": {
      "small": "size={1}",
      "medium": "size={2}",
      "large": "size={3}"
    }
  },
  "layoutRules": [
    "Use vertical orientation by default with value beneath title.",
    "Use horizontal orientation when layout density or scan pattern requires side-by-side content.",
    "For horizontal orientation, adjust title top margin based on size to align text baseline with value.",
    "Do not place more than five metrics in a single dashboard view.",
    "Use visual prominence (size and position) to encode metric importance when multiple metrics are shown."
  ],
  "sizeScaleMappings": [
    {
      "size": "small",
      "valueStyle": "Display3",
      "indicatorSize": 1,
      "horizontalTitleMarginTop": "var(--salt-spacing-50)"
    },
    {
      "size": "medium",
      "valueStyle": "Display2",
      "indicatorSize": 2,
      "horizontalTitleMarginTop": "var(--salt-spacing-100)"
    },
    {
      "size": "large",
      "valueStyle": "Display1",
      "indicatorSize": 3,
      "horizontalTitleMarginTop": "var(--salt-spacing-150)"
    }
  ],
  "dataRequirements": [
    "title is required and should be concise.",
    "value is required; numeric or short string formats are acceptable.",
    "subtitle is optional and can be plain text or link.",
    "subvalue is optional and should provide comparative or contextual value.",
    "indicator direction is optional and should be derived from business logic (up/down/no indicator).",
    "for metric groups, caller must define visual hierarchy and ordering."
  ],
  "gaps": [
    {
      "type": "Missing token",
      "evidence": "Story uses literal StackLayout gap={0}.",
      "recommendation": "Prefer semantic spacing token mapping for zero/none spacing in pattern docs.",
      "label": "SOURCE_GAP"
    },
    {
      "type": "Undocumented variant combination",
      "evidence": "Docs describe size and orientation independently; not every size x orientation x context combination has a dedicated story.",
      "recommendation": "Treat matrix cells as composable from independent axes and mark inferred combinations during generation.",
      "label": "SOURCE_GAP"
    }
  ]
}