{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saltdesignsystem.com/schemas/salt-context-pack-manifest.schema.json",
  "title": "Salt Context Pack Manifest",
  "description": "Manifest for generated Salt static context artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "generator",
    "registry",
    "status",
    "entries",
    "coverage_gaps"
  ],
  "properties": {
    "contract": {
      "const": "salt_context_pack_manifest_v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "status": {
      "enum": ["validated", "unsupported"]
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "coverage_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverageGap"
      }
    }
  },
  "$defs": {
    "coverageGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "status",
        "reason",
        "missing",
        "evidence_ref_ids"
      ],
      "properties": {
        "kind": {
          "enum": [
            "component",
            "pattern",
            "foundation",
            "prompt",
            "instruction",
            "markdown_bridge"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "unsupported"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "missing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_ref_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "name",
        "output_path",
        "contract",
        "status",
        "registry",
        "generated_artifact_id",
        "generated_artifact_kind",
        "evidence_ref_ids",
        "evidence_ref_count",
        "unsupported_claim_count",
        "missing"
      ],
      "properties": {
        "kind": {
          "enum": [
            "component",
            "component_markdown",
            "pattern",
            "foundation",
            "prompt",
            "instruction"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "output_path": {
          "type": "string",
          "minLength": 1
        },
        "contract": {
          "enum": [
            "salt_context_component_v1",
            "salt_context_component_markdown_v1",
            "salt_context_pattern_v1",
            "salt_context_foundation_v1",
            "salt_context_prompt_instruction_surface_v1"
          ]
        },
        "status": {
          "enum": ["validated", "unsupported"]
        },
        "registry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "version": {
              "type": ["string", "null"]
            },
            "hash": {
              "type": ["string", "null"]
            },
            "generated_at": {
              "type": ["string", "null"]
            }
          }
        },
        "generated_artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "generated_artifact_kind": {
          "enum": [
            "component-context",
            "component-markdown-bridge",
            "pattern-context",
            "foundation-context",
            "prompt",
            "instruction"
          ]
        },
        "evidence_ref_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
