{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saltdesignsystem.com/schemas/salt-context-component-check.schema.json",
  "title": "Salt Component Context Check",
  "description": "Staleness check result for one generated Salt component context artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "status",
    "current",
    "supported",
    "output_path",
    "component_id",
    "component_name",
    "evidence_ref_ids",
    "mismatches",
    "missing"
  ],
  "properties": {
    "contract": {
      "const": "salt_context_component_check_v1"
    },
    "status": {
      "enum": ["current", "stale", "unsupported"]
    },
    "current": {
      "type": "boolean"
    },
    "supported": {
      "type": "boolean"
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    },
    "component_id": {
      "type": "string",
      "minLength": 1
    },
    "component_name": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ref_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mismatches": {
      "type": "array",
      "items": {
        "enum": [
          "contract",
          "registry",
          "status",
          "component",
          "surface_gate",
          "evidence_refs",
          "unsupported_claims",
          "generated_artifact"
        ]
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
