{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saltdesignsystem.com/schemas/salt-changes.schema.json",
  "type": "object",
  "required": ["generated_at", "version", "changes"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "package",
          "target_type",
          "target_name",
          "version",
          "release_type",
          "kind",
          "summary",
          "details",
          "source_urls",
          "last_verified_at"
        ]
      }
    }
  }
}
