{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jpmorganchase/salt-ds/blob/main/packages/semantic-core/schemas/salt-pattern-validation-rule-pack.schema.json",
  "title": "Salt Pattern Validation Rule Pack",
  "description": "Source-backed rule pack for validating expected Salt pattern implementation evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "id",
    "generated_at",
    "generator",
    "registry",
    "rules"
  ],
  "properties": {
    "contract": {
      "const": "salt_pattern_validation_rule_pack_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "ruleKind": {
      "enum": [
        "starter-template-import",
        "starter-region",
        "starter-region-order",
        "starter-build-around",
        "starter-preserve-constraint",
        "pattern-accessibility-summary"
      ]
    },
    "ruleStatus": {
      "enum": ["supported", "unsupported"]
    },
    "match": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "package"],
          "properties": {
            "kind": {
              "const": "salt_import"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "package": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "text"],
          "properties": {
            "kind": {
              "const": "text_presence"
            },
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pattern_id",
        "pattern_name",
        "kind",
        "status",
        "field_path",
        "value",
        "match",
        "message",
        "unsupported_reason",
        "evidence_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "pattern_id": {
          "type": "string",
          "minLength": 1
        },
        "pattern_name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/ruleKind"
        },
        "status": {
          "$ref": "#/$defs/ruleStatus"
        },
        "field_path": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "unsupported_reason": {
          "type": ["string", "null"]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "salt-evidence-ref.schema.json"
          }
        },
        "canonical_source": {
          "type": ["string", "null"]
        },
        "source_urls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
