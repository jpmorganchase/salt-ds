{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jpmorganchase/salt-ds/blob/main/packages/semantic-core/schemas/salt-context-unsupported-surface.schema.json",
  "title": "Salt Unsupported Generated Context Surface",
  "description": "Explicit unsupported state for generated context surfaces that cannot emit EvidenceRef-backed Salt claims yet.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "generator",
    "registry",
    "status",
    "surface",
    "evidence_refs",
    "unsupported_claims",
    "surface_gate",
    "generated_artifact"
  ],
  "properties": {
    "contract": {
      "const": "salt_context_unsupported_surface_v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "$ref": "#/$defs/generator"
    },
    "registry": {
      "$ref": "#/$defs/registry"
    },
    "status": {
      "const": "unsupported"
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "name",
        "status",
        "reason",
        "missing",
        "evidence_ref_ids"
      ],
      "properties": {
        "kind": {
          "enum": ["prompt", "instruction"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "unsupported"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "missing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_ref_ids": {
          "type": "array",
          "maxItems": 0
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "maxItems": 0
    },
    "unsupported_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "salt-generated-artifact.schema.json#/$defs/unsupportedClaim"
      }
    },
    "surface_gate": {
      "$ref": "#/$defs/surfaceGate"
    },
    "generated_artifact": {
      "allOf": [
        {
          "$ref": "salt-generated-artifact.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "claims": {
              "type": "array",
              "maxItems": 0
            },
            "evidence_refs": {
              "type": "array",
              "maxItems": 0
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "surfaceGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "validation_issues",
        "missing",
        "unsupported_claim_count",
        "artifact_id",
        "artifact_kind"
      ],
      "properties": {
        "status": {
          "const": "unsupported"
        },
        "validation_issues": {
          "type": "array"
        },
        "missing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unsupported_claim_count": {
          "type": "integer",
          "minimum": 1
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_kind": {
          "enum": ["prompt", "instruction"]
        }
      }
    }
  }
}
