{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saltdesignsystem.com/schemas/salt-context-component.schema.json",
  "title": "Salt Component Context",
  "description": "Evidence-aware static context for one Salt component.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "generator",
    "registry",
    "status",
    "component",
    "evidence_refs",
    "unsupported_claims",
    "surface_gate",
    "generated_artifact"
  ],
  "properties": {
    "contract": {
      "const": "salt_context_component_v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "status": {
      "enum": ["validated", "unsupported"]
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "package_name",
        "status",
        "import",
        "summary",
        "props",
        "accessibility",
        "examples"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "$ref": "#/$defs/evidenceText"
        },
        "package_name": {
          "$ref": "#/$defs/evidenceText"
        },
        "status": {
          "$ref": "#/$defs/evidenceText"
        },
        "import": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/componentImport" }]
        },
        "summary": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/evidenceText" }]
        },
        "props": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prop"
          }
        },
        "accessibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary"],
          "properties": {
            "summary": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/evidenceText"
              }
            }
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/example"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "salt-evidence-ref.schema.json"
      }
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "$ref": "salt-generated-artifact.schema.json#/$defs/unsupportedClaim"
      }
    },
    "surface_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "validation_issues",
        "missing",
        "unsupported_claim_count",
        "artifact_id",
        "artifact_kind"
      ],
      "properties": {
        "status": {
          "enum": ["validated", "unsupported"]
        },
        "validation_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceValidationIssue"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unsupported_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_kind": {
          "const": "component-context"
        }
      }
    },
    "generated_artifact": {
      "$ref": "salt-generated-artifact.schema.json"
    }
  },
  "$defs": {
    "evidenceRefIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "evidence_ref_ids"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "componentImport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "export_name",
        "statement",
        "evidence_ref_ids"
      ],
      "properties": {
        "package_name": {
          "type": "string",
          "minLength": 1
        },
        "export_name": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "prop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "required",
        "description",
        "deprecated",
        "evidence_ref_ids"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "allowed_values": {
          "type": "array",
          "items": {
            "type": ["string", "number", "boolean"]
          }
        },
        "deprecated": {
          "type": "boolean"
        },
        "deprecation_note": {
          "type": ["string", "null"]
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "code",
        "source_url",
        "evidence_ref_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "evidenceValidationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "path"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
