{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saltdesignsystem.com/schemas/salt-context-coverage-audit.schema.json",
  "title": "Salt Context Coverage Audit",
  "description": "Coverage audit for source-backed Salt generated component, pattern, and foundation contexts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "generator",
    "registry",
    "status",
    "component_contexts",
    "pattern_contexts",
    "foundation_contexts",
    "docs_registry_gaps"
  ],
  "properties": {
    "contract": {
      "const": "salt_context_coverage_audit_v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "$ref": "#/$defs/generator"
    },
    "registry": {
      "$ref": "#/$defs/registry"
    },
    "status": {
      "enum": ["validated", "unsupported"]
    },
    "component_contexts": {
      "$ref": "#/$defs/section"
    },
    "pattern_contexts": {
      "$ref": "#/$defs/section"
    },
    "foundation_contexts": {
      "$ref": "#/$defs/section"
    },
    "docs_registry_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap"
      }
    }
  },
  "$defs": {
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_records",
        "selected_records",
        "validated_contexts",
        "unsupported_contexts",
        "source_gap_count",
        "unsupported_records"
      ],
      "properties": {
        "total_records": {
          "type": "integer",
          "minimum": 0
        },
        "selected_records": {
          "type": "integer",
          "minimum": 0
        },
        "validated_contexts": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_contexts": {
          "type": "integer",
          "minimum": 0
        },
        "source_gap_count": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unsupportedRecord"
          }
        }
      }
    },
    "unsupportedRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "missing",
        "unsupported_claim_count",
        "validation_issue_count",
        "evidence_ref_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "unsupported"
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unsupported_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "validation_issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_ref_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "name",
        "status",
        "reason",
        "missing",
        "evidence_ref_ids"
      ],
      "properties": {
        "kind": {
          "enum": ["component", "pattern", "foundation"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "unsupported"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "missing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_ref_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
