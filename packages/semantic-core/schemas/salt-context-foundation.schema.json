{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jpmorganchase/salt-ds/blob/main/packages/semantic-core/schemas/salt-context-foundation.schema.json",
  "title": "Salt Foundation Context",
  "description": "Evidence-aware static context for one Salt foundation token category.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "generator",
    "registry",
    "status",
    "foundation",
    "evidence_refs",
    "unsupported_claims",
    "surface_gate",
    "generated_artifact"
  ],
  "properties": {
    "contract": {
      "const": "salt_context_foundation_v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "$ref": "#/$defs/generator"
    },
    "registry": {
      "$ref": "#/$defs/registry"
    },
    "status": {
      "enum": ["validated", "unsupported"]
    },
    "foundation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "category", "tokens"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "const": "tokens"
        },
        "category": {
          "$ref": "#/$defs/evidenceText"
        },
        "tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "salt-evidence-ref.schema.json"
      }
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "$ref": "salt-generated-artifact.schema.json#/$defs/unsupportedClaim"
      }
    },
    "surface_gate": {
      "$ref": "#/$defs/surfaceGate"
    },
    "generated_artifact": {
      "$ref": "salt-generated-artifact.schema.json"
    }
  },
  "$defs": {
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "evidenceRefIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "evidence_ref_ids"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "evidenceBoolean": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "evidence_ref_ids"],
      "properties": {
        "value": {
          "type": "boolean"
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "token": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "type",
        "value",
        "semantic_intent",
        "deprecated",
        "guidance",
        "policy"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/evidenceText"
        },
        "category": {
          "$ref": "#/$defs/evidenceText"
        },
        "type": {
          "$ref": "#/$defs/evidenceText"
        },
        "value": {
          "$ref": "#/$defs/evidenceText"
        },
        "semantic_intent": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/evidenceText" }]
        },
        "deprecated": {
          "$ref": "#/$defs/evidenceBoolean"
        },
        "guidance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceText"
          }
        },
        "policy": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/tokenPolicy" }]
        }
      }
    },
    "tokenPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usage_tier",
        "direct_component_use",
        "preferred_for",
        "avoid_for",
        "notes",
        "docs",
        "structural_roles",
        "pairing"
      ],
      "properties": {
        "usage_tier": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/evidenceText" }]
        },
        "direct_component_use": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/evidenceText" }]
        },
        "preferred_for": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceText"
          }
        },
        "avoid_for": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceText"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceText"
          }
        },
        "docs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tokenDoc"
          }
        },
        "structural_roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceText"
          }
        },
        "pairing": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/pairing" }]
        }
      }
    },
    "tokenDoc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["href", "evidence_ref_ids"],
      "properties": {
        "href": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "pairing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "role", "level", "evidence_ref_ids"],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": ["string", "null"]
        },
        "evidence_ref_ids": {
          "$ref": "#/$defs/evidenceRefIds"
        }
      }
    },
    "surfaceGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "validation_issues",
        "missing",
        "unsupported_claim_count",
        "artifact_id",
        "artifact_kind"
      ],
      "properties": {
        "status": {
          "enum": ["validated", "unsupported"]
        },
        "validation_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceValidationIssue"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unsupported_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_kind": {
          "const": "foundation-context"
        }
      }
    },
    "evidenceValidationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "path"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
