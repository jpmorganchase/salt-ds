{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saltdesignsystem.com/schemas/salt-token-policy-structural-role-rule-pack.schema.json",
  "title": "Salt Token Policy Structural Role Rule Pack",
  "description": "Source-backed rule pack for deriving generated token structural roles and pairings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "id",
    "generated_at",
    "generator",
    "registry",
    "rules"
  ],
  "properties": {
    "contract": {
      "const": "salt_token_policy_structural_role_rule_pack_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": ["string", "null"]
        },
        "hash": {
          "type": ["string", "null"]
        },
        "generated_at": {
          "type": ["string", "null"]
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "ruleKind": {
      "enum": [
        "container-pairing",
        "separable-token",
        "fixed-size",
        "border-style"
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "kind",
        "match",
        "emits",
        "evidence_text",
        "evidence_terms",
        "evidence_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/ruleKind"
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "emits": {
          "$ref": "#/$defs/emits"
        },
        "evidence_text": {
          "type": "string",
          "minLength": 1
        },
        "evidence_terms": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "salt-evidence-ref.schema.json"
          }
        },
        "canonical_source": {
          "type": ["string", "null"]
        },
        "source_urls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category"],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "token_family": {
          "type": ["string", "null"]
        },
        "token_property": {
          "type": ["string", "null"]
        },
        "token_modifier": {
          "type": ["string", "null"]
        }
      }
    },
    "emits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structural_role_templates", "conditions"],
      "properties": {
        "structural_role_templates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pairing_template": {
          "anyOf": [
            {
              "$ref": "#/$defs/pairingTemplate"
            },
            {
              "type": "null"
            }
          ]
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pairingTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "role"],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
