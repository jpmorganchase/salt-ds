{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salt.design/schemas/project-conventions-stack.schema.json",
  "title": "Salt Project Conventions Stack",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "layers"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "contract": {
      "const": "project_conventions_stack_v1"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/layer"
      }
    }
  },
  "$defs": {
    "scope": {
      "enum": ["line_of_business", "team", "repo", "other"]
    },
    "fileSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "file"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "packageSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "specifier"],
      "properties": {
        "type": {
          "const": "package"
        },
        "specifier": {
          "type": "string",
          "minLength": 1
        },
        "export": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "$ref": "#/$defs/fileSource"
        },
        {
          "$ref": "#/$defs/packageSource"
        }
      ]
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "source"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "description": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      }
    }
  }
}
