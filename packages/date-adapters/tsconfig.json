{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@salt-ds/date-adapters": ["./types/index.ts"]
    },
    "declaration": false,
    "outDir": "./dist",
    "module": "commonjs",
    "target": "es2016",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
