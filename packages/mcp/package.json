{
  "name": "@salt-ds/mcp",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpmorganchase/salt-ds.git",
    "directory": "packages/mcp"
  },
  "bugs": "https://github.com/jpmorganchase/salt-ds/issues",
  "main": "src/index.ts",
  "sideEffects": false,
  "files": [
    "bin",
    "generated",
    "schemas"
  ],
  "publishBinEntrypoints": {
    "bin/salt-mcp.js": {
      "requirePath": "../dist-cjs/mcp/src/index.js",
      "errorPrefix": "salt-mcp error:"
    }
  },
  "publishExports": {
    ".": {
      "types": "./dist-types/mcp/src/index.d.ts",
      "import": "./dist-es/mcp/src/index.js",
      "require": "./dist-cjs/mcp/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "typescriptInclude": [
    "src",
    "../semantic-core/src"
  ],
  "typescriptRootDir": "..",
  "bin": {
    "salt-mcp": "bin/salt-mcp.js"
  },
  "scripts": {
    "build:package": "yarn node ../../scripts/build.mjs",
    "build:registry": "node ./scripts/buildRegistry.mjs",
    "sync:generated": "node ./scripts/syncGenerated.mjs",
    "build": "yarn build:package && yarn build:registry && yarn sync:generated",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/semver": "^7.7.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "minisearch": "^7.2.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "semver": "^7.7.3",
    "typescript": "^6.0.0",
    "unified": "^11.0.5",
    "zod": "^4.1.11"
  },
  "publishConfig": {
    "directory": "../../dist/salt-ds-mcp",
    "provenance": true
  }
}
