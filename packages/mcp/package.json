{
  "name": "@salt-ds/mcp",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpmorganchase/salt-ds.git",
    "directory": "packages/mcp"
  },
  "bugs": "https://github.com/jpmorganchase/salt-ds/issues",
  "main": "src/index.ts",
  "sideEffects": false,
  "files": [
    "bin"
  ],
  "publishBinEntrypoints": {
    "bin/salt-mcp.js": {
      "requirePath": "../dist-cjs/mcp/src/index.js",
      "errorPrefix": "salt-mcp error:"
    }
  },
  "publishExports": {
    ".": {
      "types": "./dist-types/mcp/src/index.d.ts",
      "import": "./dist-es/mcp/src/index.js",
      "require": "./dist-cjs/mcp/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "typescriptInclude": [
    "src"
  ],
  "typescriptRootDir": "src",
  "publishBundledWorkspaceDependencies": [
    "@salt-ds/runtime-inspector-core",
    "@salt-ds/runtime-inspector-browser",
    "@salt-ds/semantic-core"
  ],
  "publishAdditionalEntryPaths": [
    "src/evals/runWorkflowEval.ts",
    "src/evals/runWorkflowEvalReplay.ts",
    "src/evals/runHostTraceEval.ts"
  ],
  "publishExtraCopyPaths": [
    {
      "from": "../semantic-core/generated",
      "to": "generated"
    },
    {
      "from": "../semantic-core/schemas",
      "to": "schemas"
    }
  ],
  "bin": {
    "salt-mcp": "bin/salt-mcp.js"
  },
  "scripts": {
    "build": "yarn workspace @salt-ds/semantic-core build && yarn node ../../scripts/build.mjs",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@salt-ds/runtime-inspector-browser": "workspace:*",
    "@salt-ds/runtime-inspector-core": "workspace:*",
    "@salt-ds/semantic-core": "workspace:*",
    "get-tsconfig": "^4.7.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1"
  },
  "publishConfig": {
    "directory": "../../dist/salt-ds-mcp",
    "provenance": true
  }
}
