      "workflow": "create",
      "prompt": "Build a Salt app shell with a left VerticalNavigation, a page header, and a main content region.",
      "capability_tags": ["navigation", "composition", "gate-integrity"],
      "practical_gates": [
        "yarn typecheck",
        "yarn workspace @salt-ds/mcp build",
        "yarn smoke:consumer --skip-build"
      ],
      "expectations": {
        "required_imports": [
          {
            "package": "@salt-ds/core",
            "names": [
              "VerticalNavigation",
              "VerticalNavigationItem",
              "VerticalNavigationItemContent",
              "VerticalNavigationItemLabel",
              "VerticalNavigationItemTrigger"
            ]
          }
        ],
        "required_ancestors": [
          {
            "child": "VerticalNavigationItemTrigger",
            "ancestor": "VerticalNavigationItemContent",
            "rule_id": "composition.vertical-navigation-item-content",
            "required": true
          }
        ],
        "banned_patterns": ["fake_href"],
        "unresolved_probe_names": ["DefinitelyMissingSaltExport"]
