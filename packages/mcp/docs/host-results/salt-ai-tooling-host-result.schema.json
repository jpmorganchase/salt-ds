{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salt-ds.github.io/schemas/salt-ai-tooling-host-result.schema.json",
  "title": "Salt AI tooling host benchmark result",
  "description": "Release-evidence schema for one real or local Salt AI tooling host benchmark artifact.",
  "type": "object",
  "required": [
    "schema",
    "host",
    "runner",
    "date",
    "repo",
    "transport",
    "setup_smoke_check_result",
    "mcp_status",
    "cli_fallback_status",
    "setup",
    "results",
    "not_run",
    "overall"
  ],
  "properties": {
    "schema": {
      "const": "salt_ai_tooling_host_result_v1"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "runner": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "transport": {
      "$ref": "#/$defs/transport"
    },
    "salt_cli_version": {
      "type": "string",
      "minLength": 1
    },
    "salt_mcp_package_version": {
      "type": "string",
      "minLength": 1
    },
    "setup_smoke_check_result": {
      "type": "string",
      "minLength": 1
    },
    "mcp_status": {
      "type": "string",
      "minLength": 1
    },
    "cli_fallback_status": {
      "type": "string",
      "minLength": 1
    },
    "setup": {
      "type": "object",
      "minProperties": 1
    },
    "results": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/scenarioResult"
      }
    },
    "not_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "not_claimed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "overall": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": {
          "enum": ["passed", "partial", "failed"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "anyOf": [
    {
      "required": ["salt_cli_version"]
    },
    {
      "required": ["salt_mcp_package_version"]
    }
  ],
  "allOf": [
    {
      "$ref": "#/$defs/containsS1"
    },
    {
      "$ref": "#/$defs/containsS2"
    },
    {
      "$ref": "#/$defs/containsS3"
    },
    {
      "$ref": "#/$defs/containsS4"
    },
    {
      "$ref": "#/$defs/containsS5"
    },
    {
      "$ref": "#/$defs/containsS6"
    },
    {
      "$ref": "#/$defs/containsS7"
    },
    {
      "$ref": "#/$defs/containsS8"
    },
    {
      "$ref": "#/$defs/containsS9"
    }
  ],
  "$defs": {
    "transport": {
      "enum": ["mcp", "cli", "mixed", "host", "manual"]
    },
    "failureClassification": {
      "enum": [
        "host_instruction",
        "mcp_transport",
        "workflow_contract",
        "evidence_gap",
        "agent_behavior",
        "repo_policy",
        "visual_evidence",
        "runtime_validation",
        "cli_fallback"
      ]
    },
    "scenarioResult": {
      "type": "object",
      "required": [
        "scenario",
        "name",
        "transport",
        "outcome",
        "compact_fields_captured",
        "observed",
        "failure_classification",
        "notes"
      ],
      "properties": {
        "scenario": {
          "enum": ["S1", "S2", "S3", "S4", "S5", "S6", "S7", "S8", "S9"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "transport": {
          "$ref": "#/$defs/transport"
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": "integer"
        },
        "outcome": {
          "enum": [
            "passed",
            "failed",
            "partial",
            "blocked",
            "guardrail_pass",
            "not_run",
            "skipped"
          ]
        },
        "compact_fields_captured": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "observed": {
          "type": "object"
        },
        "failure_classification": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureClassification"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "not_claimed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "containsS1": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S1"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS2": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S2"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS3": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S3"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS4": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S4"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS5": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S5"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS6": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S6"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS7": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S7"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS8": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S8"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    },
    "containsS9": {
      "properties": {
        "results": {
          "contains": {
            "type": "object",
            "properties": {
              "scenario": {
                "const": "S9"
              }
            },
            "required": ["scenario"]
          },
          "minContains": 1
        }
      }
    }
  },
  "additionalProperties": true
}
