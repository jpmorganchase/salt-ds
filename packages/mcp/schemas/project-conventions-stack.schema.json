{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jpmorganchase/salt-ds/blob/main/packages/mcp/schemas/project-conventions-stack.schema.json",
  "title": "Salt Project Conventions Stack",
  "description": "Layered repo-local, data-only project conventions resolved by Salt MCP. Layers are loaded in declared order; later layers override earlier ones. Every layer must point to a JSON file contained within the declared repo root. Salt MCP never imports or requires executable policy modules.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "layers"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "contract": {
      "const": "project_conventions_stack_v1"
    },
    "notes": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "string",
        "maxLength": 4096
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/layer"
      }
    }
  },
  "$defs": {
    "scope": {
      "enum": ["line_of_business", "team", "repo", "other"]
    },
    "fileSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "file"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "source": {
      "$ref": "#/$defs/fileSource"
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "source"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "description": {
          "type": "string",
          "maxLength": 4096
        },
        "optional": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      }
    }
  }
}
